{
  "name": "workflows",
  "private": true,
  "description": "Agent Workflow Protocol — POC contracts, fixtures, and tooling",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "sync-engine-poc-schema": "node scripts/sync-engine-poc-schema.mjs",
    "check-engine-poc-schema-sync": "node scripts/sync-engine-poc-schema.mjs --check",
    "validate-workflows": "node scripts/validate-workflows.mjs",
    "engine:validate": "node packages/engine/src/cli.mjs validate",
    "engine:mcp:stdio": "node packages/engine/src/mcp-stdio-server.mjs",
    "conformance": "node conformance/run-conformance.mjs",
    "test": "npm test --workspace=@agent-workflow/engine",
    "migrate-backlog:local-map": "node scripts/migrate-backlog-to-github.mjs local-map",
    "migrate-backlog:map": "node scripts/migrate-backlog-to-github.mjs map",
    "migrate-backlog:render": "node scripts/migrate-backlog-to-github.mjs render",
    "migrate-backlog:apply": "node scripts/migrate-backlog-to-github.mjs apply",
    "migrate-backlog:wire": "node scripts/migrate-backlog-to-github.mjs wire",
    "migrate-backlog:close-done": "node scripts/migrate-backlog-to-github.mjs close-done",
    "github:set-issue-types": "node scripts/set-github-issue-types.mjs",
    "migrate-backlog:all": "node scripts/migrate-backlog-to-github.mjs all"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "yaml": "^2.8.4"
  }
}
