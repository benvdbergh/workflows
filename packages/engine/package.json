{
  "name": "@agent-workflow/engine",
  "version": "1.0.0",
  "description": "Agent Workflow Protocol — reference engine (definition validation and execution)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/benvdbergh/workflows"
  },
  "type": "module",
  "main": "./src/index.mjs",
  "exports": {
    ".": "./src/index.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src/",
    "schemas/",
    "openapi/",
    "README.md"
  ],
  "bin": {
    "workflows-engine": "src/cli.mjs",
    "workflows-engine-mcp": "src/mcp-stdio-server.mjs",
    "workflows-engine-rest": "src/rest-server.mjs"
  },
  "scripts": {
    "prepack": "node ../../scripts/sync-engine-schema.mjs",
    "test": "node --test test/*.mjs",
    "mcp:stdio": "node ./src/mcp-stdio-server.mjs",
    "rest:serve": "node ./src/rest-server.mjs"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.20.0",
    "jq-wasm": "^1.1.0-jq-1.8.1",
    "zod": "^4.4.3"
  }
}
