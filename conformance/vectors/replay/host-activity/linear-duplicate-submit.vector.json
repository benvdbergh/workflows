{
  "id": "replay.host_activity.linear.duplicate_submit",
  "description": "Second submit after completion is rejected with ACTIVITY_SUBMIT_NOT_AWAITING; no extra commands appended.",
  "kind": "replay",
  "definition": "examples/conformance-host-activity-linear.workflow.json",
  "input": {},
  "activityExecutionMode": "host_mediated",
  "historyPrefix": [
    {
      "kind": "event",
      "name": "ExecutionStarted",
      "payload": {
        "workflowName": "conformance-host-linear",
        "workflowVersion": "1.0.0",
        "inputKeys": []
      }
    },
    {
      "kind": "command",
      "name": "ScheduleNode",
      "payload": { "nodeId": "start" }
    },
    {
      "kind": "event",
      "name": "NodeScheduled",
      "payload": { "nodeId": "start" }
    },
    {
      "kind": "command",
      "name": "CompleteNode",
      "payload": { "nodeId": "start", "output": {} }
    },
    {
      "kind": "event",
      "name": "StateUpdated",
      "payload": { "nodeId": "start", "state": {} }
    },
    {
      "kind": "command",
      "name": "ScheduleNode",
      "payload": { "nodeId": "work" }
    },
    {
      "kind": "event",
      "name": "NodeScheduled",
      "payload": { "nodeId": "work" }
    },
    {
      "kind": "event",
      "name": "ActivityRequested",
      "payload": { "nodeId": "work", "nodeType": "tool_call" }
    }
  ],
  "activitySubmissions": [
    {
      "nodeId": "work",
      "outcome": { "ok": true, "result": { "out": "once" } }
    },
    {
      "nodeId": "work",
      "outcome": { "ok": true, "result": { "out": "twice" } },
      "expectFailure": { "code": "ACTIVITY_SUBMIT_NOT_AWAITING" }
    }
  ],
  "expect": {
    "status": "completed",
    "tailCommands": [
      { "name": "CompleteNode", "nodeId": "work" },
      { "name": "ScheduleNode", "nodeId": "end" },
      { "name": "CompleteNode", "nodeId": "end" }
    ]
  }
}
