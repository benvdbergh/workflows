      "payload": {
        "workflowName": "conformance-host-par",
        "workflowVersion": "1.0.0",
        "inputKeys": []
      }
    },
    {
      "kind": "command",
      "name": "ScheduleNode",
      "payload": { "nodeId": "start" }
    },
    {
      "kind": "event",
      "name": "NodeScheduled",
      "payload": { "nodeId": "start" }
    },
    {
      "kind": "command",
      "name": "CompleteNode",
      "payload": { "nodeId": "start", "output": {} }
    },
    {
      "kind": "event",
      "name": "StateUpdated",
      "payload": { "nodeId": "start", "state": {} }
    },
    {
      "kind": "command",
      "name": "ScheduleNode",
      "payload": { "nodeId": "fork" }
    },
    {
      "kind": "event",
      "name": "NodeScheduled",
      "payload": { "nodeId": "fork" }
    },
    {
