      "payload": { "nodeId": "a1" }
    },
    {
      "kind": "event",
      "name": "ActivityRequested",
      "payload": {
        "nodeId": "a1",
        "nodeType": "tool_call",
        "parallelSpan": {
          "parallelNodeId": "fork",
          "joinTargetId": "join",
          "branchName": "only",
          "branchEntryNodeId": "a1"
        }
      }
    }
