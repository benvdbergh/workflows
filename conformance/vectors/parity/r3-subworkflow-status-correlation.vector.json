  "description": "subworkflow status exposes child_execution_id and parent_execution_id after parent completion.",
  "kind": "parity",
  "definition": "examples/conformance-subworkflow-parent.workflow.json",
  "executionId": "parity-subworkflow-status-1",
  "stubActivityOutputs": {
    "run_tests": { "tests_passed": true }
  },
  "steps": [
    {
